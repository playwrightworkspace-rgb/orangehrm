{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "types": [
      "node",
      "@playwright/test"
    ],
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./dist"
  },

  "include": [
    "features/**/*.ts",
    "step-definitions/**/*.ts",
    "pages/**/*.ts",
    "hooks/**/*.ts",
    "utils/**/*.ts"
  ]
}